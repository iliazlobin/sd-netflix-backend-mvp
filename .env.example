# Netflix MVP — Environment Configuration
# Copy to .env and adjust for local development.
# docker-compose reads this file via env_file: .env

# Host port for the app (default 8010). Override at deploy time.
# APP_PORT=8010

# Postgres connection string (asyncpg). Default targets the compose db service.
# DATABASE_URL=postgresql+asyncpg://netflix:netflix@db:5432/netflix

# Bind address inside the container (always 0.0.0.0).
# HOST=0.0.0.0

# Port the app listens on inside the container (always 8000).
# PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO

# Comma-separated allowed CORS origins (* for development).
# CORS_ORIGINS=*

# Directory containing mock .ts video segment files (inside container).
# MOCK_SEGMENTS_DIR=/app/data/segments
