# Netflix MVP — Environment Configuration
# Copy to .env and adjust for local development.
# The app reads settings from environment variables; docker-compose provides them.

# --- Database ---
# Postgres connection string (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://netflix:netflix@db:5432/netflix

# --- App ---
# Host to bind the server to.
HOST=0.0.0.0
# Port the app listens on inside the container (always 8000).
PORT=8000
# Log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins (use * for development).
CORS_ORIGINS=*

# --- Mock Segments ---
# Directory containing mock .ts video segment files.
MOCK_SEGMENTS_DIR=/app/data/segments
